# PostgreSQL (Aiven or local). Example:
# DATABASE_URL="postgresql://user:password@localhost:5432/keystone?schema=public"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/keystone?schema=public"

# Auth.js / NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-long-random-string"
AUTH_URL="http://localhost:3000"
# Netlify: set the same vars in the dashboard; for branch/preview deploys, enable
# "Deploy previews" (and Branch deploys) on each variable — not Production-only.

# AES-256 key for encrypting Secret notes (exactly 32 bytes as base64).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SECRETS_ENCRYPTION_KEY=""

# Optional: max upload size for file notes (MB)
UPLOAD_MAX_MB="10"
