# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=keystone
POSTGRES_USER=keystone
POSTGRES_PASSWORD=changeme

# ── API server ────────────────────────────────────────────────────────────────
PORT=3001

# API Key — single shared secret for your private instance.
# Generate a strong random value, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=replace_me_with_a_long_random_string

# AES-256 encryption key — must be exactly 64 hex characters (32 bytes).
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=replace_me_with_64_hex_chars_00000000000000000000000000000000

# ── Frontend ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS (no trailing slash)
ALLOWED_ORIGINS=http://localhost:3000

# Public URL of the API (used by the Vite build in production)
VITE_API_URL=http://localhost:3001

# ── Docker ports (optional overrides) ────────────────────────────────────────
API_PORT=3001
CLIENT_PORT=3000
